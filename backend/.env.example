APP_NAME="Blossfechten Riga"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# API backend URL
APP_URL=https://api.blossfechten.fraksis.com
# Vue frontend URL (used by CORS and Sanctum)
FRONTEND_URL=https://blossfechten.fraksis.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# --- Session / CSRF (cross-subdomain: blossfechten.fraksis.com <-> api.blossfechten.fraksis.com) ---
# Leading dot makes the cookie available to all subdomains.
SESSION_DOMAIN=.blossfechten.fraksis.com
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# SameSite=none required when frontend and API are on different subdomains
# and the browser treats them as cross-site (e.g. fraksis.com is a shared host).
# Must be paired with SESSION_SECURE_COOKIE=true.
SESSION_SAME_SITE=none
SESSION_SECURE_COOKIE=true

# Sanctum stateful domains — frontend origin without protocol or port 443.
SANCTUM_STATEFUL_DOMAINS=blossfechten.fraksis.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="hello@blossfechtenriga.com"
MAIL_FROM_NAME="${APP_NAME}"

# Address that receives public contact-form submissions.
CONTACT_RECIPIENT=viitinsh@gmail.com
